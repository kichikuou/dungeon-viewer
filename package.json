{
  "name": "dungeon-viewer",
  "version": "1.0.0",
  "description": "Dungeon file viewer for Rance VI / GALZOO Island",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "type": "cd src && tsc",
    "build": "esbuild src/index.ts --bundle --outdir=dist --minify --sourcemap --format=esm",
    "serve": "esbuild src/index.ts --bundle --outdir=dist --minify --sourcemap --format=esm --watch --servedir=dist"
  },
  "author": "kichikuou <KichikuouChrome@gmail.com>",
  "dependencies": {
    "@types/three": "^0.135.0",
    "arg": "^5.0.0",
    "esbuild": "^0.27.3",
    "three": "^0.135.0",
    "typescript": "^5.9.3"
  }
}
